{
  "name": "nginxpulse-scripts",
  "version": "0.1.0",
  "private": true,
  "description": "NginxPulse 脚本聚合入口",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "help": "bash ./scripts/pnpm_help.sh",
    "dev:local": "bash ./scripts/dev_local.sh",
    "build:single": "bash ./scripts/build_single.sh",
    "docs:sync": "bash ./scripts/sync_fumadocs_docs.sh",
    "docs:dev": "bash ./scripts/dev_fumadocs.sh",
    "docs:build": "bash ./scripts/build_fumadocs.sh",
    "wiki:push": "bash ./scripts/push_wiki.sh",
    "docker:publish": "bash ./scripts/publish_docker.sh -r magiccoders/nginxpulse",
    "docker:publish:beta": "bash ./scripts/publish_docker_beta.sh -r magiccoders/nginxpulse",
    "docker:verify-latest": "bash ./scripts/verify_docker_latest.sh -r magiccoders/nginxpulse",
    "assets:crop-supporters": "bash ./scripts/crop_supporters.sh",
    "db:schema:render": "python3 ./scripts/render_pg_schema.py",
    "website:ids": "python3 ./scripts/website_ids.py",
    "web:dev": "pnpm --dir ./webapp dev",
    "web:build": "pnpm --dir ./webapp build",
    "web:preview": "pnpm --dir ./webapp preview",
    "mobile:dev": "pnpm --dir ./webapp_mobile dev",
    "mobile:build": "pnpm --dir ./webapp_mobile build",
    "mobile:preview": "pnpm --dir ./webapp_mobile preview",
    "fumadocs:dev": "bash ./scripts/dev_fumadocs.sh",
    "fumadocs:build": "bash ./scripts/build_fumadocs.sh"
  }
}
