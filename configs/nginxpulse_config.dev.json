{
  "websites": [
    {
      "name": "GZ Log Test",
      "logPath": "var/log/gz-log-read-test/*.gz",
      "whitelist": {
        "enabled": false,
        "ips": [
        ],
        "cities": [],
        "nonMainland": false
      },
      "domains": ["localhost"]
    },
    {
      "name": "Caddy Log Test",
      "logPath": "var/log/nginx-pulse-demo/access_caddy.json",
      "logType": "caddy",
      "domains": ["localhost"]
    },
    {
      "name": "雷池日志",
      "logPath": "var/log/leichi/accesslog_1",
      "logType": "safeline",
      "domains": ["localhost"]
    },
    {
      "name": "sftp站点",
      "logPath": "",
      "domains": [
        "kaisir.cn"
      ],
      "logType": "nginx",
      "logFormat": "",
      "logRegex": "",
      "timeLayout": "",
      "sources": [
        {
          "id": "sftp-main",
          "type": "sftp",
          "pollInterval": "5s",
          "path": "/home/likai/web-services/nginx_data/logs/kaisir/access.log",
          "host": "192.168.6.131",
          "port": 22,
          "user": "root",
          "auth": {
            "keyFile": "/Users/likai/.ssh/nginxpulse_sftp"
          }
        }
      ]
    }
  ],
  "system": {
    "logDestination": "file",
    "taskInterval": "1m",
    "logRetentionDays": 100,
    "ipGeoCacheLimit": 1000000,
    "ipGeoApiUrl": "http://ip-api.com/batch",
    "parseBatchSize": 100,
    "demoMode": false,
    "accessKeys": [],
    "language": "zh-CN",
    "mobilePwaEnabled": false
  },
  "database": {
    "driver": "postgres",
    "dsn": "postgres://nginxpulse:nginxpulse@127.0.0.1:5432/nginxpulse?sslmode=disable",
    "maxOpenConns": 10,
    "maxIdleConns": 5,
    "connMaxLifetime": "30m"
  },
  "server": {
    "Port": ":8089"
  },
  "pvFilter": {
    "statusCodeInclude": [
      200
    ],
    "excludePatterns": [
      "favicon.ico$",
      "robots.txt$",
      "sitemap.xml$",
      "^/health$",
      "^/_(?:nuxt|next)/",
      "rss.xml$",
      "feed.xml$",
      "atom.xml$"
    ],
    "excludeIPs": ["127.0.0.1", "::1", "10.10.0.1", "192.168.30.21"]
  }
}
