# NginxPulse OAuth2 配置示例
# 复制此文件为 .env 并根据实际情况修改

# ===== OAuth2 配置 =====
# 启用 OAuth2
OAUTH2_ENABLED=true

# OAuth2 提供商名称：github, google, custom
OAUTH2_PROVIDER_NAME=github

# OAuth2 客户端 ID
OAUTH2_CLIENT_ID=your-github-client-id

# OAuth2 客户端密钥
OAUTH2_CLIENT_SECRET=your-github-client-secret

# OAuth2 回调地址（必须与提供商配置的一致）
OAUTH2_REDIRECT_URL=http://localhost:8088/auth/callback

# OAuth2 授权范围（逗号分隔）
# GitHub: read:user,user:email
# Google: openid,email,profile
OAUTH2_SCOPES=read:user,user:email

# 自定义提供商端点（仅当 providerName=custom 时需要）
# OAUTH2_AUTH_URL=https://your-idp.com/oauth/authorize
# OAUTH2_TOKEN_URL=https://your-idp.com/oauth/token
# OAUTH2_USER_INFO_URL=https://your-idp.com/oauth/userinfo

# Session 超时时间
OAUTH2_SESSION_TIMEOUT=24h

# ===== 数据库配置 =====
DB_DRIVER=postgres
DB_DSN=postgres://user:password@localhost:5432/nginxpulse?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# ===== 服务器配置 =====
SERVER_PORT=8088

# ===== 网站配置（JSON 格式） =====
WEBSITES=[{"name":"示例网站","logPath":"/share/logs/access.log","domains":["example.com"]}]

# ===== 其他系统配置 =====
LOG_DEST=file
TASK_INTERVAL=1m
LOG_RETENTION_DAYS=30
LOG_PARSE_BATCH_SIZE=100
IP_GEO_CACHE_LIMIT=1000000
IP_GEO_API_URL=http://ip-api.com/batch
DEMO_MODE=false
ACCESS_KEYS=
ACCESS_KEY_EXPIRE_DAYS=7
APP_LANGUAGE=zh-CN
MOBILE_PWA_ENABLED=false
